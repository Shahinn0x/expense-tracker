<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Update Expense</title>
</head>
<body style="<%- styles.CONTAINER_STYLE %>">
  <div style="text-align: center; margin-bottom: -20px;">
    <a href="/expense-list" style="color: #337ab7; text-decoration: none; font-weight: bold;">Back to List</a>
  </div>
  <div style="<%- styles.CARD_STYLE %>">
    <h2 style="margin-top: 0; text-align: center;">Update Expense</h2>
    <form action="/update-expense/<%= expense.id %>" method="POST">
      <label>Expense Name:</label>
      <input type="text" name="name" value="<%= expense.name %>" style="<%- styles.INPUT_STYLE %>" required>

      <label>Amount:</label>
      <input type="number" step="0.01" name="amount" value="<%= expense.amount %>" style="<%- styles.INPUT_STYLE %>" required>

      <label>Date:</label>
      <input type="date" name="date" value="<%= expense.date %>" style="<%- styles.INPUT_STYLE %>" required>

      <label>Description:</label>
      <textarea name="description" rows="4" style="<%- styles.INPUT_STYLE %> height: auto;"><%= expense.description %></textarea>

      <button type="submit" style="<%- styles.BUTTON_GREEN %>">Update Expense</button>
    </form>
  </div>
</body>
</html>